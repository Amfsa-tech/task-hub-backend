# Database Configuration
MONGO_URI=mongodb://localhost:27017/taskhub

# JWT Configuration (tokens never expire)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# QoreID NIN Verification API Configuration
QOREID_CLIENT_ID=ZUQ34D5WQJ2B86OOXMT7
QOREID_SECRET_KEY=0ca3b4df6ae84782a05e6f12c728d3af

# OneSignal Push Notification Configuration
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_KEY=your-onesignal-rest-api-key

# Resend API Key (used for all transactional emails)
RESEND_API_KEY=your-resend-api-key

# Frontend Configuration (for email links)
FRONTEND_URL=http://localhost:3000

# CORS Configuration (comma-separated origins; supports wildcard entries like *.onrender.com)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Server Configuration
PORT=5000
NODE_ENV=development

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100 